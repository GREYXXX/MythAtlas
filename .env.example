# Backend
DATABASE_URL=postgresql+asyncpg://mythatlas:mythatlas@localhost:5432/mythatlas
ADMIN_TOKEN=dev-admin-change-me
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

# Embeddings — two options (local is default when OPENAI_API_KEY is blank):
#
#   Option A: Local via Ollama (free, requires: ollama serve + ollama pull nomic-embed-text)
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_EMBEDDING_MODEL=nomic-embed-text
#
#   Option B: OpenAI (set key to override local — also enables AI story generation)
OPENAI_API_KEY=

# Frontend (Vite dev): defaults to proxy /api -> backend
# VITE_API_BASE=/api

# Docker Compose (optional overrides)
# ADMIN_TOKEN=
# CORS_ORIGINS=
# OPENAI_API_KEY=
